node {

    def registryProjet = 'registry.gitlab.com/nassmima/registrydocker'
    def IMAGE = "${registryProjet}:version.${env.BUILD_ID}"

    stage('Clone') {
        git branch: 'main', url: 'https://github.com/NassimaMoussi/jbuild.git'
    }

    stage('Build') {
        def img = docker.build("${IMAGE}", '.')
        env.IMG = img.id
    }

    stage('Run') {
        sh "docker run -d --name run-${env.BUILD_ID} -p 86:80 ${IMAGE}"
        sh "docker exec run-${env.BUILD_ID} curl http://localhost"
    }

    stage('Push') {
        docker.withRegistry('https://registry.gitlab.com', 'reg1') {
            def img = docker.image("${IMAGE}")
            img.push('latest')
            img.push("version.${env.BUILD_ID}")
        }
    }
}
